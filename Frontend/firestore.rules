rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCounterOnlyUpdate(allowedKeys) {
      return isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function isValidNotificationCreate(userId) {
      return isSignedIn() &&
        request.resource.data.keys().hasOnly([
          'type',
          'targetType',
          'receiverUid',
          'actorUid',
          'actorName',
          'actorAvatarUrl',
          'message',
          'subject',
          'quote',
          'eventId',
          'postId',
          'replyId',
          'read',
          'createdAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'type',
          'targetType',
          'receiverUid',
          'actorUid',
          'actorName',
          'message',
          'read',
          'createdAt'
        ]) &&
        request.resource.data.receiverUid == userId &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.read == false &&
        request.resource.data.createdAt == request.time &&
        (
          request.resource.data.type == 'like' ||
          request.resource.data.type == 'reply' ||
          request.resource.data.type == 'follow' ||
          request.resource.data.type == 'invite'
        ) &&
        (
          request.resource.data.targetType == 'discussionPost' ||
          request.resource.data.targetType == 'discussionReply' ||
          request.resource.data.targetType == 'experiencePost' ||
          request.resource.data.targetType == 'event' ||
          request.resource.data.targetType == 'user'
        );
    }
    
    // 活动集合的规则（event-posters）
    match /event-posters/{document=**} {
      // 所有人都可以读取活动列表和详情
      allow read: if true;

      // 只有登录用户可以创建活动
      allow create: if request.auth != null;

      // 只有活动创建者可以更新活动
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.organizerId;

      // 只有活动创建者可以删除活动
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.organizerId;
    }

    // 活动集合的规则(events)
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.organizerId;

      // 论坛帖子
      match /posts/{postId} {
        allow read: if true;
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn() && (
          request.auth.uid == resource.data.userId ||
          isCounterOnlyUpdate(['likeCount', 'replyCount'])
        );
        allow delete: if isSignedIn() &&
          request.auth.uid == resource.data.userId;

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isSignedIn() &&
            request.resource.data.userId == request.auth.uid;
          allow update: if isSignedIn() && (
            request.auth.uid == resource.data.userId ||
            isCounterOnlyUpdate(['likeCount'])
          );
          allow delete: if isSignedIn() &&
            request.auth.uid == resource.data.userId;

          match /likes/{userId} {
            allow read: if true;
            allow create, delete: if isSignedIn() && request.auth.uid == userId;
          }
        }

        match /likes/{userId} {
          allow read: if true;
          allow create, delete: if isSignedIn() && request.auth.uid == userId;
        }
      }

      // Longer-form event experiences shown on the standalone Forum page.
      match /forumPosts/{postId} {
        allow read: if true;
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn() && (
          request.auth.uid == resource.data.userId ||
          isCounterOnlyUpdate(['likeCount', 'replyCount'])
        );
        allow delete: if isSignedIn() &&
          request.auth.uid == resource.data.userId;

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isSignedIn() &&
            request.resource.data.userId == request.auth.uid;
          allow update: if isSignedIn() && (
            request.auth.uid == resource.data.userId ||
            isCounterOnlyUpdate(['likeCount'])
          );
          allow delete: if isSignedIn() &&
            request.auth.uid == resource.data.userId;

          match /likes/{userId} {
            allow read: if true;
            allow create, delete: if isSignedIn() && request.auth.uid == userId;
          }
        }

        match /likes/{userId} {
          allow read: if true;
          allow create, delete: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }

    // 用户集合的规则
    match /users/{userId} {
      // 只有登录用户可以读取自己的用户信息
      allow read: if request.auth != null && request.auth.uid == userId;

      // 只有登录用户可以创建、更新或删除自己的用户信息
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;

      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isValidNotificationCreate(userId);
        allow update: if isSignedIn() &&
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isSignedIn() && (
          request.auth.uid == userId ||
          resource.data.actorUid == request.auth.uid
        );
      }
    }
  }
}
